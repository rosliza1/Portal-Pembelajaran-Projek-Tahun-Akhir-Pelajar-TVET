DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============================================================
# SUPABASE DEPLOYMENT INSTRUCTIONS
# ============================================================
# When deploying to Supabase, make these 2 changes:
#
# 1. In prisma/schema.prisma, change:
#      provider = "sqlite"
#    to:
#      provider = "postgresql"
#
# 2. Replace the DATABASE_URL above with your Supabase connection:
#    DATABASE_URL=postgresql://postgres:Airul%40026jtm@db.wbinwhbmkszeiguwebkl.supabase.co:5432/postgres
#    (Note: the @ in the password is URL-encoded as %40)
#
# 3. Run: bun run db:push  (creates tables in Supabase)
# 4. Run: bun run prisma/seed.ts  (populates dummy data)
#
# OR: Run supabase-complete.sql directly in Supabase SQL Editor
#     (contains both schema + seed data in one file)
# ============================================================
