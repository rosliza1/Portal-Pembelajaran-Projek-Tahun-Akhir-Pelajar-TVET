# ============================================================
# Portal FYP TVET (JTM) — Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# Database (Supabase PostgreSQL)
# Format: postgresql://postgres:[PASSWORD_URL_ENCODED]@db.[PROJECT_REF].supabase.co:5432/postgres
# Note: URL-encode special characters in password (@ -> %40)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Session secret for signing JWT tokens (change to a random string in production)
SESSION_SECRET=change-this-to-a-random-secret-key

# Z.AI API key is auto-configured via z-ai-web-dev-sdk in the sandbox.
# For production deployment, set:
# ZAI_API_KEY=your-zai-api-key
